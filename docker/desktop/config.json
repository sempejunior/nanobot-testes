    "whatsapp": { "enabled": false, "bridgeUrl": "ws://localhost:3001" },
    "discord": { "enabled": false, "token": "" },
    "slack": { "enabled": false, "appToken": "", "botToken": "" },
    "feishu": { "enabled": false, "appId": "", "appSecret": "" },
    "dingtalk": { "enabled": false, "clientId": "", "clientSecret": "" },
    "qq": { "enabled": false, "appId": "", "appSecret": "" },
    "email": { "enabled": false },
    "mochat": { "enabled": false }
  },
  "gateway": {
    "heartbeat": {
      "enabled": false,
      "interval_s": 3600
    }
  }
