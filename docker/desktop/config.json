      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.7,
      "maxTokens": 4096,
      "maxToolIterations": 10,
      "memoryWindow": 10
    }
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": ""
      }
    },
    "exec": {
      "timeout": 30
    },
